{
  "name": "storytype",
  "version": "0.1.0",
  "private": true,
  "description": "A modern Vue 3 component development pattern with TypeScript, Atomic Design, and Storybook",
  "keywords": [
    "vue3",
    "typescript",
    "storybook",
    "atomic-design",
    "component-library",
    "design-system"
  ],
  "author": "Sidarta Veloso <sidartaveloso@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sidartaveloso/storytype.git"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,vue,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,vue,json,md}\"",
    "test": "turbo run test",
    "test:report": "open coverage/index.html",
    "test:report:docs": "pnpm --filter docs exec playwright show-report",
    "clean": "turbo run clean && rm -rf node_modules .turbo coverage",
    "docs:dev": "pnpm --filter docs dev",
    "docs:build": "pnpm --filter docs build",
    "docs:preview": "pnpm --filter docs preview",
    "release": "semantic-release",
    "release:dry": "semantic-release --dry-run",
    "commit": "cz"
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.5",
    "commitizen": "^4.3.1",
    "cz-conventional-changelog": "^3.3.0",
    "prettier": "^3.8.3",
    "semantic-release": "^25.0.3",
    "taskin": "^3.0.3",
    "turbo": "^2.9.6",
    "typescript": "^6.0.3",
    "vite": "^6.4.2"
  }
}
