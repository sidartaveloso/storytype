{
  "name": "@storytype/cli",
  "version": "0.1.0",
  "description": "CLI tool for scaffolding Storytype components",
  "keywords": [
    "cli",
    "vue3",
    "generator",
    "scaffold",
    "storytype"
  ],
  "author": "Sidarta Veloso <sidartaveloso@gmail.com>",
  "license": "MIT",
  "type": "module",
  "bin": {
    "storytype": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "templates",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/cli.ts src/index.ts --format esm --dts",
    "dev": "tsup src/cli.ts src/index.ts --format esm --dts --watch",
    "clean": "rm -rf dist",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "@storytype/core": "workspace:*",
    "commander": "^12.0.0",
    "prompts": "^2.4.2",
    "chalk": "^5.3.0",
    "ora": "^8.0.1",
    "fs-extra": "^11.2.0"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^20.11.30",
    "@types/prompts": "^2.4.9",
    "tsup": "^8.0.2",
    "typescript": "^5.4.5"
  }
}
