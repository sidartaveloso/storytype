{
  "name": "storytype",
  "version": "0.2.3",
  "description": "CLI tool for scaffolding Storytype components and analyzing project structure",
  "keywords": [
    "cli",
    "vue3",
    "generator",
    "scaffold",
    "storytype",
    "atomic-design",
    "component-analyzer",
    "vue",
    "typescript"
  ],
  "author": "Sidarta Veloso <sidartaveloso@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sidartaveloso/storytype.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/sidartaveloso/storytype/issues"
  },
  "homepage": "https://github.com/sidartaveloso/storytype#readme",
  "type": "module",
  "bin": {
    "storytype": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src/templates",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/cli.ts src/index.ts --format esm --dts && pnpm build:templates",
    "build:templates": "mkdir -p dist/templates && cp -r src/templates/* dist/templates/",
    "dev": "tsup src/cli.ts src/index.ts --format esm --dts --watch",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "fs-extra": "^11.2.0",
    "handlebars": "^4.7.8",
    "ora": "^8.0.1",
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/handlebars": "^4.1.0",
    "@types/node": "^20.11.30",
    "@types/prompts": "^2.4.9",
    "tsup": "^8.0.2",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  }
}
